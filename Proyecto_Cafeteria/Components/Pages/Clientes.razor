@page "/clientes"
@inject CafeteriaWeb.Models.CafeteriaContext DB
@using CafeteriaWeb.Models
@using Microsoft.EntityFrameworkCore
@rendermode InteractiveServer

<PageTitle>Clientes — Cafetería</PageTitle>

<div class="dashboard">
    <h1>👥 Gestión de Clientes</h1>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <p style="color:green; font-weight:bold;">@mensaje</p>
    }

    <h2>@(modoEdicion ? "✏️ Editar Cliente" : "➕ Nuevo Cliente")</h2>

    <div class="formulario">
        <input placeholder="Nombre completo *"
               value="@clienteActual.Nombre"
               @oninput="@(e => clienteActual.Nombre = e.Value!.ToString()!)" />

        <input placeholder="Teléfono *"
               value="@clienteActual.Telefono"
               @oninput="@(e => clienteActual.Telefono = e.Value!.ToString()!)" />

        <input placeholder="Email *"
               value="@clienteActual.Email"
               @oninput="@(e => clienteActual.Email = e.Value!.ToString()!)" />

        @if (!string.IsNullOrEmpty(errorFormulario))
        {
            <p style="color:red;">@errorFormulario</p>
        }

        <div style="display:flex; gap:1rem;">
            <button class="btn-guardar" @onclick="GuardarCliente">
                💾 @(modoEdicion ? "Actualizar" : "Guardar")
            </button>
            @if (modoEdicion)
            {
                <button class="btn-cancelar" @onclick="CancelarEdicion">
                    ✖ Cancelar
                </button>
            }
        </div>
    </div>

    <h2>📋 Clientes registrados (@clientes.Count)</h2>

    @if (clientes.Count == 0)
    {
        <p>No hay clientes registrados aún.</p>
    }
    else
    {
        <table class="tabla-clientes">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Nombre</th>
                    <th>Teléfono</th>
                    <th>Email</th>
                    <th>Fecha registro</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in clientes)
                {
                    <tr>
                        <td>@c.Id</td>
                        <td>@c.Nombre</td>
                        <td>@c.Telefono</td>
                        <td>@c.Email</td>
                        <td>@c.FechaRegistro.ToShortDateString()</td>
                        <td>
                            <button class="btn-editar" @onclick="() => EditarCliente(c)">✏️</button>
                            <button class="btn-eliminar" @onclick="() => ConfirmarEliminar(c)">🗑️</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (clienteAEliminar != null)
    {
        <div class="modal">
            <div class="modal-contenido">
                <p>¿Estás seguro que deseas eliminar a <strong>@clienteAEliminar.Nombre</strong>?</p>
                <div style="display:flex; gap:1rem; justify-content:center;">
                    <button class="btn-eliminar" @onclick="EliminarCliente">Sí, eliminar</button>
                    <button class="btn-cancelar" @onclick="() => clienteAEliminar = null">Cancelar</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    List<Cliente> clientes = new();
    Cliente clienteActual = new();
    Cliente? clienteAEliminar = null;
    bool modoEdicion = false;
    string mensaje = "";
    string errorFormulario = "";

    protected override async Task OnInitializedAsync()
    {
        await CargarClientes();
    }

    async Task CargarClientes()
    {
        clientes = await DB.Clientes.OrderByDescending(c => c.FechaRegistro).ToListAsync();
    }

    async Task GuardarCliente()
    {
        errorFormulario = "";

        if (string.IsNullOrWhiteSpace(clienteActual.Nombre) ||
            string.IsNullOrWhiteSpace(clienteActual.Telefono) ||
            string.IsNullOrWhiteSpace(clienteActual.Email))
        {
            errorFormulario = "⚠️ Todos los campos son obligatorios.";
            return;
        }

        try
        {
            if (modoEdicion)
            {
                var clienteExistente = await DB.Clientes.FindAsync(clienteActual.Id);
                if (clienteExistente != null)
                {
                    clienteExistente.Nombre = clienteActual.Nombre;
                    clienteExistente.Telefono = clienteActual.Telefono;
                    clienteExistente.Email = clienteActual.Email;
                }
                mensaje = "✅ Cliente actualizado correctamente.";
            }
            else
            {
                clienteActual.FechaRegistro = DateTime.Now;
                DB.Clientes.Add(clienteActual);
                mensaje = "✅ Cliente registrado correctamente.";
            }

            await DB.SaveChangesAsync();
            clienteActual = new();
            modoEdicion = false;
            await CargarClientes();
        }
        catch (Exception ex)
        {
            errorFormulario = $"❌ Error al guardar: {ex.Message}";
        }
    }

    void EditarCliente(Cliente c)
    {
        clienteActual = new Cliente
        {
            Id = c.Id,
            Nombre = c.Nombre,
            Telefono = c.Telefono,
            Email = c.Email,
            FechaRegistro = c.FechaRegistro
        };
        modoEdicion = true;
        mensaje = "";
    }

    void ConfirmarEliminar(Cliente c)
    {
        clienteAEliminar = c;
    }

    async Task EliminarCliente()
    {
        if (clienteAEliminar != null)
        {
            DB.Clientes.Remove(clienteAEliminar);
            await DB.SaveChangesAsync();
            clienteAEliminar = null;
            mensaje = "✅ Cliente eliminado correctamente.";
            await CargarClientes();
        }
    }

    void CancelarEdicion()
    {
        clienteActual = new();
        modoEdicion = false;
        errorFormulario = "";
    }
}
@page "/"
@inject IHttpClientFactory HttpClientFactory
@inject CafeteriaWeb.Models.CafeteriaContext DB
@using CafeteriaWeb.Models
@using Microsoft.EntityFrameworkCore
@rendermode InteractiveServer

<PageTitle>Catpuccino — Inicio</PageTitle>

<!-- ====== BANNER SUPERIOR ====== -->

<div class="hero-banner">

    <div class="hero-content">

        <img src="images/catpuccino-logo.png"
             alt="Catpuccino Logo"
             class="logo-circular" />

        <div>
            <h1>Catpuccino</h1>
            <p class="hero-subtitle">
                Café con catitud • Comidas y Bebidas
            </p>
        </div>

    </div>

</div>

<!-- ====== DASHBOARD ====== -->

<div class="dashboard">

    <h2>Bienvenido a Catpuccino</h2>

    <p class="subtitulo">
        Sistema de gestión de pedidos
    </p>

    <div class="tarjetas">

        <div class="tarjeta">
            <h3>👥 Clientes registrados</h3>
            <p class="numero">@totalClientes</p>
        </div>

        <div class="tarjeta">
            <h3>🍽️ Platillos disponibles</h3>
            <p class="numero">@totalPlatillos</p>
        </div>

        <div class="tarjeta">
            <h3>📋 Pedidos del día</h3>
            <p class="numero">@pedidosHoy</p>
        </div>

    </div>

    <div class="accesos">
        <a href="/catalogo">🍴 Ver Catálogo</a>
        <a href="/clientes">👥 Gestionar Clientes</a>
        <a href="/pedidos">📋 Registrar Pedido</a>
    </div>

</div>

@code {
    int totalClientes = 0;
    int totalPlatillos = 0;
    int pedidosHoy = 0;

    protected override async Task OnInitializedAsync()
    {
        // Datos de tu BD
        totalClientes = await DB.Clientes.CountAsync();

        pedidosHoy = await DB.Pedidos
            .Where(p => p.Fecha.Date == DateTime.Today)
            .CountAsync();

        // Dato de la API
        try
        {
            var http = HttpClientFactory.CreateClient("ApiProfesor");

            var platillos = await http.GetFromJsonAsync<List<Platillo>>(
                "/api/alimentacion/platillos"
            );

            totalPlatillos = platillos?.Count ?? 0;
        }
        catch
        {
            totalPlatillos = 0;
        }
    }
}
@page "/"
@inject IHttpClientFactory HttpClientFactory
@inject CafeteriaWeb.Models.CafeteriaContext DB
@using CafeteriaWeb.Models
@using Microsoft.EntityFrameworkCore
@rendermode InteractiveServer

<PageTitle>Cafetería — Inicio</PageTitle>

<div class="dashboard">
    <h1>☕ Bienvenido a la Cafetería</h1>
    <p class="subtitulo">Sistema de gestión de pedidos</p>

    <div class="tarjetas">

        <div class="tarjeta">
            <h3>👥 Clientes registrados</h3>
            <p class="numero">@totalClientes</p>
        </div>

        <div class="tarjeta">
            <h3>🍽️ Platillos disponibles</h3>
            <p class="numero">@totalPlatillos</p>
        </div>

        <div class="tarjeta">
            <h3>📋 Pedidos del día</h3>
            <p class="numero">@pedidosHoy</p>
        </div>

    </div>

    <div class="accesos">
        <a href="/catalogo">🍴 Ver Catálogo</a>
        <a href="/clientes">👥 Gestionar Clientes</a>
        <a href="/pedidos">📋 Registrar Pedido</a>
    </div>
</div>

@code {
    int totalClientes = 0;
    int totalPlatillos = 0;
    int pedidosHoy = 0;

    protected override async Task OnInitializedAsync()
    {
        // Datos de tu BD
        totalClientes = await DB.Clientes.CountAsync();
        pedidosHoy = await DB.Pedidos
            .Where(p => p.Fecha.Date == DateTime.Today)
            .CountAsync();

        // Dato de la API — protegido con try/catch
        try
        {
            var http = HttpClientFactory.CreateClient("ApiProfesor");
            var platillos = await http.GetFromJsonAsync<List<Platillo>>("/api/alimentacion/platillos");
            totalPlatillos = platillos?.Count ?? 0;
        }
        catch
        {
            totalPlatillos = 0;
        }
    }
}